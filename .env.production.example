# Variáveis do stack de produção (Portainer > Stacks > Environment variables).
# NÃO comite o .env real.

# Imagem publicada (CI publica no GHCR a cada push na main)
IMAGE=ghcr.io/inovoxa/gestaojuridica:latest

# Domínio público (Traefik faz o TLS)
APP_DOMAIN=advocaciaoliveira.cloud
TRAEFIK_CERTRESOLVER=letsencrypt
# Nome REAL da rede overlay do seu Traefik (veja: docker network ls)
TRAEFIK_NETWORK=traefik-public
# Nome do entrypoint HTTPS do seu Traefik (comum: websecure ou https)
TRAEFIK_ENTRYPOINT=websecure

# Banco
POSTGRES_PASSWORD=troque-esta-senha-forte

# Segredos da app (gere com: openssl rand -base64 32)
AUTH_SECRET=troque-auth-secret
CREDENTIALS_ENCRYPTION_KEY=troque-chave-32-bytes-base64

# Migração/seed
# Na PRIMEIRA subida, deixe RUN_SEED=true para criar o escritório/usuários demo.
# Depois volte para false para não tentar recriar dados.
RUN_SEED=false

# Storage (local | s3 | gdrive)
STORAGE_DRIVER=local
DOC_DELETION_DELAY_DAYS=30
# S3/MinIO (se STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=legaltech-docs
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Google (Calendar + Drive) — opcional. Redirect: https://APP_DOMAIN/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
