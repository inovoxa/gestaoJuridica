# ============================================================
# LegalTech BR — variáveis de ambiente (copie para .env)
# ============================================================

# --- Banco de dados ---
DATABASE_URL="postgresql://legaltech:legaltech@localhost:5432/legaltech?schema=public"

# --- Redis (fila BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- Auth.js ---
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao"
AUTH_URL="http://localhost:3000"

# --- Criptografia de credenciais em repouso (tokens Chatwoot/IA/DataJud) ---
# Chave de 32 bytes em base64. Gere com: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY="troque-esta-chave-de-32-bytes-base64"

# --- Storage (local | s3 | gdrive) ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage"
# S3 / MinIO (quando STORAGE_DRIVER=s3)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="legaltech-docs"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# --- Chatwoot (CRM) — configurável também por escritório no banco ---
CHATWOOT_BASE_URL="https://crm.exemplo.com.br"
CHATWOOT_API_TOKEN=""

# --- DataJud (CNJ) — Fase 2 ---
DATAJUD_API_KEY=""

# --- Provedores de IA — Fase 3 (chaves também por escritório no banco) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GROK_API_KEY=""

# --- App ---
NODE_ENV="development"
APP_URL="http://localhost:3000"
