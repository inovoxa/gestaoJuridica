// LegalTech BR — Schema Prisma (single-tenant: uma instância por escritório)
// Inclui o domínio jurídico + o conteúdo do website público do escritório.
// Mapeado do módulo Odoo eb_law_management (referência funcional).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Escritório (singleton) — identidade, endereço e website
// ============================================================

/// Dados do escritório. Deve existir exatamente UM registro por instância.
model Firm {
  id        String  @id @default("firm")
  name      String
  legalName String?
  cnpj      String?
  oab       String? // inscrição OAB do escritório

  // Contato / endereço (exibidos no website e nos documentos)
  email      String?
  phone      String?
  whatsapp   String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  zip        String?
  mapsUrl    String?
  latitude   Float?
  longitude  Float?

  // Branding
  logoUrl       String?
  primaryColor  String? @default("#C9A227") // dourado institucional
  socialLinks   Json? // { instagram, linkedin, facebook, ... }

  // Conteúdo do website público
  tagline     String?
  heroTitle   String?
  heroSubtitle String?
  aboutTitle  String?
  aboutBody   String?
  siteActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Áreas de atuação exibidas no website.
model PracticeArea {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  icon        String? // nome do ícone lucide
  summary     String?
  description String?
  order       Int     @default(0)
  active      Boolean @default(true)
}

/// Mensagens recebidas pelo formulário de contato do website (viram lead no Chatwoot).
model ContactMessage {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  subject      String?
  message      String
  practiceArea String?
  status       String   @default("new") // new | contacted | archived
  syncedToCrm  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ============================================================
// Usuários e papéis (RBAC)
// ============================================================

enum UserRole {
  ADMIN_ESCRITORIO
  ADVOGADO
  SECRETARIA
  CLIENTE_PORTAL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ADVOGADO)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lawyer        Lawyer?
  clientProfile Client?      @relation("ClientPortalUser")
  caseLawyers   CaseLawyer[]
  auditLogs     AuditLog[]
}

/// Advogado (Odoo: hr.employee com is_lawyer). Tem perfil público para o website.
model Lawyer {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  name   String
  oab    String?
  oabUf  String?
  email  String?
  phone  String?
  active Boolean @default(true)

  // Perfil público (website)
  publicProfile Boolean @default(false)
  title         String? // ex.: "Sócio fundador"
  bio           String?
  photoUrl      String?
  specialties   String?
  order         Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responsibleCases Case[]       @relation("CaseResponsibleLawyer")
  caseLawyers      CaseLawyer[]
  hearings         Hearing[]
}

// ============================================================
// Clientes (Odoo: res.partner com is_law_client)
// ============================================================

model Client {
  id                String   @id @default(cuid())
  portalUserId      String?  @unique
  portalUser        User?    @relation("ClientPortalUser", fields: [portalUserId], references: [id], onDelete: SetNull)
  name              String
  cpfCnpj           String?
  email             String?
  phone             String?
  /// ID do contato correspondente no Chatwoot (sync bidirecional).
  chatwootContactId String?
  street            String?
  city              String?
  state             String?
  zip               String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cases     Case[]
  documents Document[]

  @@index([chatwootContactId])
}

// ============================================================
// Processos (Odoo: law.case) — núcleo
// ============================================================

enum CaseStage {
  DRAFT
  IN_PROGRESS
  WON
  LOST
  SETTLED
  CANCELLED
}

model CaseType {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String?
  cases       Case[]
}

model Case {
  id                     String     @id @default(cuid())
  caseNumber             String     @unique
  cnjNumber              String?
  stage                  CaseStage  @default(DRAFT)
  clientId               String
  client                 Client     @relation(fields: [clientId], references: [id])
  responsibleLawyerId    String?
  responsibleLawyer      Lawyer?    @relation("CaseResponsibleLawyer", fields: [responsibleLawyerId], references: [id], onDelete: SetNull)
  caseTypeId             String?
  caseType               CaseType?  @relation(fields: [caseTypeId], references: [id], onDelete: SetNull)
  courtId                String?
  court                  Court?     @relation(fields: [courtId], references: [id], onDelete: SetNull)
  judgeId                String?
  judge                  Judge?     @relation(fields: [judgeId], references: [id], onDelete: SetNull)
  oppositeParty          String?
  /// Segredo de justiça: restringe visibilidade mesmo dentro do escritório.
  confidential           Boolean    @default(false)
  outcomeNotes           String?
  chatwootCardId         String?
  chatwootConversationId String?
  registrationDate       DateTime   @default(now())
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  caseLawyers CaseLawyer[]
  hearings    Hearing[]
  deadlines   Deadline[]
  documents   Document[]
  evidences   Evidence[]
  tasks       Task[]
  invoices    Invoice[]
  events      CalendarEvent[]
  datajudProcess DatajudProcess?

  @@index([stage])
  @@index([cnjNumber])
}

enum CaseLawyerPermission {
  READ
  WRITE
}

model CaseLawyer {
  id         String               @id @default(cuid())
  caseId     String
  case       Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  lawyerId   String
  lawyer     Lawyer               @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  permission CaseLawyerPermission @default(READ)
  isOwner    Boolean              @default(false)

  @@unique([caseId, lawyerId])
  @@index([lawyerId])
}

// ============================================================
// Tribunais e juízes
// ============================================================

model Court {
  id      String  @id @default(cuid())
  name    String
  city    String?
  state   String?
  contact String?
  judges  Judge[]
  cases   Case[]
}

model Judge {
  id      String  @id @default(cuid())
  name    String
  courtId String?
  court   Court?  @relation(fields: [courtId], references: [id], onDelete: SetNull)
  contact String?
  cases   Case[]
}

// ============================================================
// Audiências + Agenda
// ============================================================

enum HearingStage {
  SCHEDULED
  COMPLETED
  ADJOURNED
}

model Hearing {
  id            String       @id @default(cuid())
  caseId        String
  case          Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name          String
  hearingDate   DateTime
  durationHours Float        @default(1)
  lawyerId      String?
  lawyer        Lawyer?      @relation(fields: [lawyerId], references: [id], onDelete: SetNull)
  stage         HearingStage @default(SCHEDULED)
  notes         String?
  ata           String?
  resultado     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  event   CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId String?        @unique

  @@index([caseId])
}

enum CalendarEventType {
  CONSULTA
  AUDIENCIA
  PRAZO
  OUTRO
}

enum CalendarEventStatus {
  SCHEDULED
  DONE
  CANCELLED
}

model CalendarEvent {
  id        String              @id @default(cuid())
  title     String
  start     DateTime
  end       DateTime?
  allDay    Boolean             @default(false)
  type      CalendarEventType   @default(OUTRO)
  status    CalendarEventStatus @default(SCHEDULED)
  caseId    String?
  case      Case?               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  notes     String?
  /// Sincronização com Google Calendar (id do evento remoto).
  googleEventId String?
  /// Origem do evento: local | google (evita loop de sincronização).
  source        String  @default("local")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  hearing  Hearing?
  deadline Deadline?

  @@index([start])
  @@index([googleEventId])
}

// ============================================================
// Prazos processuais
// ============================================================

enum DeadlineType {
  INTIMACAO
  CITACAO
  SENTENCA
  DESPACHO
  PUBLICACAO
  OUTRO
}

enum DeadlineStatus {
  PENDING
  ALERTED
  COMPLETED
  OVERDUE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Deadline {
  id           String         @id @default(cuid())
  caseId       String
  case         Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  deadlineType DeadlineType   @default(OUTRO)
  originDate   DateTime
  deadlineDate DateTime
  description  String?
  status       DeadlineStatus @default(PENDING)
  alertSent5d  Boolean        @default(false)
  alertSent3d  Boolean        @default(false)
  alertSent1d  Boolean        @default(false)
  alertSentDue Boolean        @default(false)
  taskId       String?        @unique
  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  eventId      String?        @unique
  event        CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([caseId])
  @@index([status, deadlineDate])
}

// ============================================================
// Documentos + Provas
// ============================================================

enum DocumentState {
  ACTIVE
  PENDING_DELETION
  DELETED
}

model Document {
  id                    String        @id @default(cuid())
  name                  String
  description           String?
  documentType          String?
  caseId                String?
  case                  Case?         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId              String?
  client                Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  storageDriver         String        @default("local")
  storageKey            String?
  fileName              String?
  fileSize              Int?
  mimeType              String?
  state                 DocumentState @default(ACTIVE)
  deletionRequestedDate DateTime?
  scheduledDeletionDate DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([caseId])
  @@index([clientId])
}

enum EvidenceType {
  DOCUMENT
  PHOTO
  VIDEO
  AUDIO
  OTHER
}

model Evidence {
  id             String       @id @default(cuid())
  caseId         String
  case           Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  evidenceType   EvidenceType @default(DOCUMENT)
  storageDriver  String       @default("local")
  storageKey     String?
  fileName       String?
  submittedById  String?
  submissionDate DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([caseId])
}

// ============================================================
// Tarefas e Faturamento leve
// ============================================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id        String     @id @default(cuid())
  caseId    String?
  case      Case?      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name      String
  status    TaskStatus @default(TODO)
  dueDate   DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  deadline Deadline?

  @@index([caseId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  CANCELLED
}

model Invoice {
  id       String        @id @default(cuid())
  caseId   String?
  case     Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  number   String
  amount   Decimal       @db.Decimal(12, 2)
  status   InvoiceStatus @default(DRAFT)
  dueDate  DateTime?
  issuedAt DateTime      @default(now())

  @@index([caseId])
}

// ============================================================
// Conformidade LGPD / OAB
// ============================================================

/// Consentimento escrito do cliente para uso de IA (Recomendação OAB 001/2024).
model ConsentRecord {
  id          String    @id @default(cuid())
  clientId    String
  purpose     String
  granted     Boolean   @default(false)
  grantedAt   DateTime?
  revokedAt   DateTime?
  documentRef String?
  createdAt   DateTime  @default(now())

  @@index([clientId, purpose])
}

/// Trilha de auditoria de acesso/edição a dados sensíveis (LGPD).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

// ============================================================
// Integração Chatwoot (singleton, credenciais criptografadas)
// ============================================================

model ChatwootIntegration {
  id                String   @id @default("chatwoot")
  baseUrl           String
  apiTokenEncrypted String
  chatwootAccountId String?
  defaultFunnelId   String?
  stageMap          Json?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// DataJud (CNJ) — consulta processual automática
// ============================================================

/// Configuração da integração DataJud (singleton).
model DatajudConfig {
  id                 String    @id @default("datajud")
  /// Chave pública da API DataJud (DPJ/CNJ), criptografada.
  apiKeyEncrypted    String?
  autoSync           Boolean   @default(true)
  syncIntervalHours  Int       @default(24)
  /// Extração automática de prazos a partir das movimentações.
  autoExtractDeadlines Boolean @default(true)
  deadlineBusinessDays Boolean @default(true)
  lastSync           DateTime?
  requestsThisMonth  Int       @default(0)
  monthlyLimit       Int       @default(1000)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

enum DatajudProcStatus {
  ATIVO
  ARQUIVADO
  BAIXADO
  DESCONHECIDO
}

/// Espelho de um processo obtido no DataJud, vinculado a um Case local.
model DatajudProcess {
  id                  String            @id @default(cuid())
  numeroProcesso      String            @unique
  caseId              String?           @unique
  case                Case?             @relation(fields: [caseId], references: [id], onDelete: SetNull)
  tribunalSigla       String?
  classe              String?
  assunto             String?
  orgaoJulgador       String?
  grau                String?
  status              DatajudProcStatus @default(DESCONHECIDO)
  dataAjuizamento     DateTime?
  dataUltimaMov       DateTime?
  dataUltimaVerificacao DateTime?
  rawJson             String?
  movements           DatajudMovement[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([caseId])
}

/// Movimentação processual do DataJud.
model DatajudMovement {
  id          String         @id @default(cuid())
  processId   String
  process     DatajudProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  data        DateTime?
  codigo      Int?
  descricao   String
  /// Hash para deduplicar (codigo+data+descricao).
  hash        String
  /// Prazo já extraído a partir desta movimentação?
  deadlineExtracted Boolean  @default(false)
  createdAt   DateTime       @default(now())

  @@unique([processId, hash])
  @@index([processId])
}

enum SyncLogStatus {
  SUCCESS
  ERROR
  INFO
}

model DatajudSyncLog {
  id            String        @id @default(cuid())
  action        String
  status        SyncLogStatus
  message       String?
  processNumber String?
  httpStatus    Int?
  recordsFound  Int?
  createdAt     DateTime      @default(now())

  @@index([createdAt])
}

/// Integração Google Calendar (singleton). Tokens OAuth2 criptografados em repouso.
model GoogleIntegration {
  id                 String    @id @default("google")
  /// E-mail/conta Google conectada (informativo).
  accountEmail       String?
  accessTokenEnc     String?
  refreshTokenEnc    String?
  tokenExpiry        DateTime?
  /// Calendário alvo (padrão: "primary").
  calendarId         String    @default("primary")
  /// Token de sincronização incremental (pull bidirecional).
  syncToken          String?
  /// Canal de push notifications (webhook do Google) — opcional.
  channelId          String?
  resourceId         String?
  channelExpiry      DateTime?
  syncEnabled        Boolean   @default(false)
  lastSync           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
